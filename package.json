{
  "name": "shop-platform-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace @shop-claw/web",
    "dev:admin": "npm run dev --workspace @shop-claw/admin",
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm run build --workspace @shop-claw/web",
    "build:admin": "npm run build --workspace @shop-claw/admin",
    "start:web": "npm run start --workspace @shop-claw/web",
    "start:admin": "npm run start --workspace @shop-claw/admin",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
